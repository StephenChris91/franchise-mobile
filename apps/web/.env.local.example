# ─── Database (Neon) ─────────────────────────────────────────────────────────
# Pooled connection (used by Drizzle / app queries)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Unpooled connection (used by drizzle-kit migrate)
DATABASE_URL_UNPOOLED=postgresql://user:password@host/dbname?sslmode=require

# ─── Auth.js (next-auth v5) ───────────────────────────────────────────────────
AUTH_SECRET=                        # openssl rand -base64 32
AUTH_GOOGLE_ID=                     # Google OAuth client ID
AUTH_GOOGLE_SECRET=                 # Google OAuth client secret

# ─── JWT (mobile API — /api/v1/*) ────────────────────────────────────────────
JWT_SECRET=                         # openssl rand -base64 32 (different from AUTH_SECRET)

# ─── Resend (transactional email) ────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Comma-separated list of admin emails that receive new-member notifications
ADMIN_NOTIFICATION_EMAILS=admin@example.com,pastor@example.com

# ─── Supabase (sermon storage) ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Cloudinary (profile photo uploads) ─────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ─── Pusher (real-time social feed) ──────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# ─── App URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://thefranchiselagos.com.ng
# Set to http://localhost:3000 for local development

EXPO_PUBLIC_API_URL=https://thefranchiselagos.com.ng
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
EXPO_PUBLIC_PUSHER_KEY=
EXPO_PUBLIC_PUSHER_CLUSTER=eu

# Expo CLI's remote SDK version fetch fails on Node 20 with "Body already read" (undici bug).
# This skips the network check — package versions are already pinned correctly in package.json.
EXPO_NO_DEPENDENCY_VALIDATION=1
